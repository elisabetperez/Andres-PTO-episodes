---
import Layout from "@/components/Layout.astro";
import Calendar from "@/components/Calendar.astro";
import Sticker from "@/components/Sticker.astro";
import { listEpisodes } from "@/lib/episodes";
import { episodeLabel } from "@/lib/numbering";
import { formatDateEs } from "@/lib/date-format";

let episodes: Awaited<ReturnType<typeof listEpisodes>> = [];
try {
  episodes = await listEpisodes();
} catch (err) {
  console.error("Could not list episodes:", err);
}
const today = new Date().toISOString().slice(0, 10);
const dates = episodes.map((e) => e.date);
const calendarMap = new Map(
  episodes.map((e) => [e.date, { title: e.title, label: episodeLabel(e.date, dates) ?? "" }])
);
const latest = episodes[episodes.length - 1] ?? null;
const latestLabel = latest ? (episodeLabel(latest.date, dates) ?? latest.date) : "";
const latestDate = latest ? formatDateEs(latest.date) : "";
---

<Layout variant="hero">
  <div class="c--corner-a c--corner-a--tl c--corner-a--no-pad">
    <Sticker />
  </div>
  <div class="c--corner-a c--corner-a--tr">
    <span class="c--corner-a__line">Temporada 1</span>
    <span class="c--corner-a__line c--corner-a__accent">{episodes.length}/∞ capítulos</span>
    <span class="c--corner-a__line">2026</span>
  </div>
  <div class="c--corner-a c--corner-a--br">
    <span class="c--corner-a__line">Desde May 25 — TBD</span>
    <span class="c--corner-a__line">®</span>
  </div>

  <div class="c--stage-a">
    <div class="c--stage-a__body">
      <Calendar episodes={calendarMap} today={today} initialSelected={latest?.date} />

      <div class="c--ep-info-a" id="episode-info" data-state={latest ? "filled" : "empty"}>
        <p class="c--ep-info-a__kicker" id="ep-kicker">{latest ? latestLabel : "Sin episodios"}</p>
        <h2 class="c--ep-info-a__title" id="ep-title">{latest ? latest.title : "Aún sin capítulos"}</h2>
        <p class="c--ep-info-a__date" id="ep-accent">{latestDate}</p>

        <div class="c--reactions-a" id="reactions" data-date={latest?.date ?? ""}>
          <div class="c--reactions-a__add">
            <button type="button" id="reactions-toggle" aria-label="Añadir reacción">+</button>
            <div class="c--reactions-a__picker" id="reactions-picker">
              <button type="button" data-emoji="👍">👍</button>
              <button type="button" data-emoji="❤️">❤️</button>
              <button type="button" data-emoji="😂">😂</button>
              <button type="button" data-emoji="🔥">🔥</button>
              <button type="button" data-emoji="🎉">🎉</button>
              <button type="button" data-emoji="🤯">🤯</button>
              <button type="button" data-emoji="👀">👀</button>
              <button type="button" data-emoji="🫡">🫡</button>
            </div>
          </div>
        </div>

        <div class="c--comments-a" id="comments" data-date={latest?.date ?? ""}>
          <div class="c--comments-a__list" id="comments-list"></div>
          <form class="c--comments-a__form" id="comments-form">
            <input
              class="c--comments-a__input"
              type="text"
              name="text"
              maxlength="280"
              placeholder="Comentar..."
              autocomplete="off"
            />
            <button class="c--comments-a__submit" type="submit">Enviar</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  const info = document.getElementById("episode-info")!;
  const kicker = document.getElementById("ep-kicker")!;
  const title = document.getElementById("ep-title")!;
  const accent = document.getElementById("ep-accent")!;

  const MESES = ["enero","febrero","marzo","abril","mayo","junio","julio","agosto","septiembre","octubre","noviembre","diciembre"];
  const DOW = ["domingo","lunes","martes","miércoles","jueves","viernes","sábado"];
  function formatDate(iso: string): string {
    const d = new Date(iso + "T00:00:00Z");
    if (Number.isNaN(d.getTime())) return iso;
    return `${DOW[d.getUTCDay()]}, ${d.getUTCDate()} de ${MESES[d.getUTCMonth()]} de ${d.getUTCFullYear()}`;
  }

  document.addEventListener("calendar:select", async (e) => {
    const detail = (e as CustomEvent).detail as { date: string; status: string; title: string; label: string; theme: string };
    info.dataset.state = "loading";
    kicker.textContent = detail.label || "Cargando";
    title.textContent = detail.title || "";
    accent.textContent = formatDate(detail.date);
    loadReactions(detail.date);
    loadComments(detail.date);

    try {
      const r = await fetch(`/api/episode?date=${encodeURIComponent(detail.date)}`);
      if (!r.ok) throw new Error("fetch failed");
      const data = await r.json() as { episode: { date: string; title: string; summary: string } | null };
      if (data.episode) {
        info.dataset.state = "filled";
        kicker.textContent = detail.label || `Episodio · ${data.episode.date}`;
        title.textContent = data.episode.title;
        accent.textContent = formatDate(data.episode.date);
      } else {
        info.dataset.state = "empty";
        kicker.textContent = "Sin episodio";
        title.textContent = "Día en blanco";
        accent.textContent = formatDate(detail.date);
      }
    } catch (err) {
      info.dataset.state = "error";
      kicker.textContent = "Error";
      title.textContent = "No se pudo cargar";
      accent.textContent = "vuelve a intentarlo en un momento";
    }
  });

  // -------- Reactions --------
  const reactionsRoot = document.getElementById("reactions")!;
  const picker = document.getElementById("reactions-picker")!;
  const toggleBtn = document.getElementById("reactions-toggle")!;
  let currentDate = reactionsRoot.dataset.date || "";
  let myEmail = "";

  type Reactions = Record<string, string[]>;

  function nameOnly(email: string): string {
    const at = email.indexOf("@");
    return at >= 0 ? email.slice(0, at) : email;
  }

  function renderChips(reactions: Reactions) {
    // Remove existing chips (everything except the __add wrapper).
    reactionsRoot.querySelectorAll(".c--reactions-a__chip").forEach((c) => c.remove());
    const add = reactionsRoot.querySelector(".c--reactions-a__add")!;
    for (const [emoji, users] of Object.entries(reactions)) {
      const btn = document.createElement("button");
      btn.type = "button";
      btn.className = "c--reactions-a__chip";
      if (myEmail && users.includes(myEmail)) btn.classList.add("is-mine");
      btn.dataset.emoji = emoji;
      btn.title = users.map(nameOnly).join(", ");
      const e = document.createElement("span");
      e.className = "c--reactions-a__chip__emoji";
      e.textContent = emoji;
      const c = document.createElement("span");
      c.className = "c--reactions-a__chip__count";
      c.textContent = String(users.length);
      btn.append(e, c);
      reactionsRoot.insertBefore(btn, add);
    }
  }

  async function loadReactions(date: string) {
    currentDate = date;
    reactionsRoot.dataset.date = date;
    picker.classList.remove("is-open");
    if (!date) return renderChips({});
    try {
      const r = await fetch(`/api/reactions?date=${encodeURIComponent(date)}`);
      if (!r.ok) throw new Error("fetch failed");
      const data = await r.json() as { reactions: Reactions; me: string };
      myEmail = data.me;
      renderChips(data.reactions);
    } catch {
      renderChips({});
    }
  }

  async function toggleReaction(emoji: string) {
    if (!currentDate) return;
    try {
      const r = await fetch("/api/reactions", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ date: currentDate, emoji }),
      });
      if (!r.ok) return;
      const data = await r.json() as { reactions: Reactions; me: string };
      myEmail = data.me;
      renderChips(data.reactions);
    } catch {/* silent */}
  }

  toggleBtn.addEventListener("click", () => picker.classList.toggle("is-open"));
  picker.addEventListener("click", (e) => {
    const b = (e.target as HTMLElement).closest<HTMLButtonElement>("[data-emoji]");
    if (!b) return;
    picker.classList.remove("is-open");
    toggleReaction(b.dataset.emoji!);
  });
  reactionsRoot.addEventListener("click", (e) => {
    const chip = (e.target as HTMLElement).closest<HTMLButtonElement>(".c--reactions-a__chip");
    if (chip && chip.dataset.emoji) toggleReaction(chip.dataset.emoji);
  });
  // Close picker on outside click.
  document.addEventListener("click", (e) => {
    if (!reactionsRoot.contains(e.target as Node)) picker.classList.remove("is-open");
  });

  if (currentDate) loadReactions(currentDate);

  // -------- Comments --------
  const commentsRoot = document.getElementById("comments")!;
  const commentsList = document.getElementById("comments-list")!;
  const commentsForm = document.getElementById("comments-form") as HTMLFormElement;
  const commentsInput = commentsForm.querySelector("input[name='text']") as HTMLInputElement;

  type Comment = { id: string; author: string; text: string; createdAt: string };

  function fmtTime(iso: string): string {
    const d = new Date(iso);
    if (Number.isNaN(d.getTime())) return "";
    return d.toLocaleString("es-ES", { hour: "2-digit", minute: "2-digit", day: "2-digit", month: "short" });
  }

  function renderComments(comments: Comment[]) {
    commentsList.innerHTML = "";
    for (const c of comments) {
      const item = document.createElement("div");
      item.className = "c--comments-a__item";
      const author = document.createElement("span");
      author.className = "c--comments-a__author";
      author.textContent = nameOnly(c.author);
      const text = document.createElement("span");
      text.className = "c--comments-a__text";
      text.textContent = c.text;
      const time = document.createElement("span");
      time.className = "c--comments-a__time";
      time.textContent = fmtTime(c.createdAt);
      item.append(author, text, time);
      if (c.author === myEmail) {
        const del = document.createElement("button");
        del.type = "button";
        del.className = "c--comments-a__delete";
        del.dataset.id = c.id;
        del.textContent = "Borrar";
        item.append(del);
      }
      commentsList.append(item);
    }
    commentsList.scrollTop = commentsList.scrollHeight;
  }

  async function loadComments(date: string) {
    commentsRoot.dataset.date = date;
    if (!date) return renderComments([]);
    try {
      const r = await fetch(`/api/comments?date=${encodeURIComponent(date)}`);
      if (!r.ok) throw new Error("fetch failed");
      const data = await r.json() as { comments: Comment[]; me: string };
      myEmail = data.me;
      renderComments(data.comments);
    } catch {
      renderComments([]);
    }
  }

  commentsForm.addEventListener("submit", async (e) => {
    e.preventDefault();
    const text = commentsInput.value.trim();
    const date = commentsRoot.dataset.date;
    if (!text || !date) return;
    const submit = commentsForm.querySelector(".c--comments-a__submit") as HTMLButtonElement;
    submit.disabled = true;
    try {
      const r = await fetch("/api/comments", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ date, text }),
      });
      if (r.ok) {
        const data = await r.json() as { comments: Comment[]; me: string };
        myEmail = data.me;
        renderComments(data.comments);
        commentsInput.value = "";
      }
    } catch {/* silent */}
    submit.disabled = false;
    commentsInput.focus();
  });

  commentsList.addEventListener("click", async (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>(".c--comments-a__delete");
    if (!btn) return;
    const date = commentsRoot.dataset.date;
    const id = btn.dataset.id;
    if (!date || !id) return;
    const r = await fetch(`/api/comments?date=${encodeURIComponent(date)}&id=${encodeURIComponent(id)}`, {
      method: "DELETE",
    });
    if (r.ok) {
      const data = await r.json() as { comments: Comment[]; me: string };
      renderComments(data.comments);
    }
  });

  if (currentDate) loadComments(currentDate);
</script>
