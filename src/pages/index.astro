---
import Layout from "@/components/Layout.astro";
import Calendar from "@/components/Calendar.astro";
import { listEpisodes } from "@/lib/episodes";

let episodes: Awaited<ReturnType<typeof listEpisodes>> = [];
try {
  episodes = await listEpisodes();
} catch (err) {
  console.error("Could not list episodes:", err);
}
const today = new Date().toISOString().slice(0, 10);
const episodeMap = new Map(episodes.map((e) => [e.date, e.title]));
const latest = episodes[episodes.length - 1] ?? null;
---

<Layout>
  <header class="c--page-a__header">
    <h1 class="c--page-a__title">El PTO de Andrés</h1>
    <p class="c--page-a__subtitle">Una sitcom diaria, en formato calendario.</p>
  </header>

  <div class="c--home-a">
    <Calendar episodes={episodeMap} today={today} />

    <aside class="c--episode-panel-a" id="episode-panel" data-state={latest ? "filled" : "empty"}>
      <p class="c--episode-panel-a__kicker" id="ep-kicker">
        {latest ? `Último episodio · ${latest.date}` : "Selecciona un día"}
      </p>
      <h2 class="c--episode-panel-a__title" id="ep-title">
        {latest ? latest.title : "Aún sin episodios"}
      </h2>
      <p class="c--episode-panel-a__summary" id="ep-summary">
        {latest ? latest.summary : "Cuando Andrés cuente algo, aparecerá aquí."}
      </p>
    </aside>
  </div>
</Layout>

<script>
  const panel = document.getElementById("episode-panel")!;
  const kicker = document.getElementById("ep-kicker")!;
  const title = document.getElementById("ep-title")!;
  const summary = document.getElementById("ep-summary")!;

  document.addEventListener("calendar:select", async (e) => {
    const detail = (e as CustomEvent).detail as { date: string; status: string; title: string };
    panel.dataset.state = "loading";
    kicker.textContent = `Cargando · ${detail.date}`;
    title.textContent = detail.title || "";
    summary.textContent = "";

    try {
      const r = await fetch(`/api/episode?date=${encodeURIComponent(detail.date)}`);
      if (!r.ok) throw new Error("fetch failed");
      const data = await r.json() as { episode: { date: string; title: string; summary: string } | null };
      if (data.episode) {
        panel.dataset.state = "filled";
        kicker.textContent = `Episodio · ${data.episode.date}`;
        title.textContent = data.episode.title;
        summary.textContent = data.episode.summary;
      } else {
        panel.dataset.state = "empty";
        kicker.textContent = `Sin episodio · ${detail.date}`;
        title.textContent = "Sin episodio";
        summary.textContent = "Este día está en el rango del PTO pero todavía no hay entrada.";
      }
    } catch (err) {
      panel.dataset.state = "error";
      kicker.textContent = "Error";
      title.textContent = "No se pudo cargar";
      summary.textContent = "Vuelve a intentarlo en un momento.";
    }
  });
</script>
