---
import Layout from "@/components/Layout.astro";
import Calendar from "@/components/Calendar.astro";
import ShowTitle from "@/components/ShowTitle.astro";
import { listEpisodes } from "@/lib/episodes";
import { episodeLabel } from "@/lib/numbering";

let episodes: Awaited<ReturnType<typeof listEpisodes>> = [];
try {
  episodes = await listEpisodes();
} catch (err) {
  console.error("Could not list episodes:", err);
}
const today = new Date().toISOString().slice(0, 10);
const dates = episodes.map((e) => e.date);
const calendarMap = new Map(
  episodes.map((e) => [e.date, { title: e.title, label: episodeLabel(e.date, dates) ?? "" }])
);
const latest = episodes[episodes.length - 1] ?? null;
const latestLabel = latest ? (episodeLabel(latest.date, dates) ?? latest.date) : "";
---

<Layout>
  <header class="c--page-a__header">
    <ShowTitle size="medium" accent="una sitcom diaria" />
    <p class="c--page-a__subtitle">Mayo 2026 — TBD</p>
  </header>

  <div class="c--home-a">
    <Calendar episodes={calendarMap} today={today} initialSelected={latest?.date} />

    <aside class="c--episode-panel-a" id="episode-panel" data-state={latest ? "filled" : "empty"}>
      <p class="c--episode-panel-a__kicker" id="ep-kicker">
        {latest ? latestLabel : "Selecciona un día"}
      </p>
      <h2 class="c--episode-panel-a__title" id="ep-title">
        {latest ? latest.title : "Aún sin episodios"}
      </h2>
      <p class="c--episode-panel-a__summary" id="ep-summary" hidden={!latest || !latest.summary}>
        {latest?.summary ?? ""}
      </p>
    </aside>
  </div>
</Layout>

<script>
  const panel = document.getElementById("episode-panel")!;
  const kicker = document.getElementById("ep-kicker")!;
  const title = document.getElementById("ep-title")!;
  const summary = document.getElementById("ep-summary") as HTMLParagraphElement;

  function setSummary(text: string) {
    summary.textContent = text;
    summary.hidden = !text;
  }

  document.addEventListener("calendar:select", async (e) => {
    const detail = (e as CustomEvent).detail as { date: string; status: string; title: string; label: string };
    panel.dataset.state = "loading";
    kicker.textContent = detail.label || `Cargando · ${detail.date}`;
    title.textContent = detail.title || "";
    setSummary("");

    try {
      const r = await fetch(`/api/episode?date=${encodeURIComponent(detail.date)}`);
      if (!r.ok) throw new Error("fetch failed");
      const data = await r.json() as { episode: { date: string; title: string; summary: string } | null };
      if (data.episode) {
        panel.dataset.state = "filled";
        kicker.textContent = detail.label || `Episodio · ${data.episode.date}`;
        title.textContent = data.episode.title;
        setSummary(data.episode.summary);
      } else {
        panel.dataset.state = "empty";
        kicker.textContent = `Sin episodio · ${detail.date}`;
        title.textContent = "Sin episodio";
        setSummary("");
      }
    } catch (err) {
      panel.dataset.state = "error";
      kicker.textContent = "Error";
      title.textContent = "No se pudo cargar";
      setSummary("Vuelve a intentarlo en un momento.");
    }
  });
</script>
