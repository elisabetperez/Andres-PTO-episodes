---
import Layout from "@/components/Layout.astro";
import ShowTitle from "@/components/ShowTitle.astro";
import { verifySession, isAdminEmail } from "@/lib/auth";
import { SEASONS, daysInSeason } from "@/config/seasons";
import { listLogins, listVisits } from "@/lib/audit";
import { listEpisodes } from "@/lib/episodes";
import { getReactions } from "@/lib/reactions";
import { listComments } from "@/lib/comments";
import { episodeLabel } from "@/lib/numbering";

const token = Astro.cookies.get("pto_session")?.value;
const secret = import.meta.env.SESSION_SECRET;
const session = token && secret ? verifySession(token, secret) : null;
const isAuthed = !!session;
const isAdmin = isAdminEmail(session?.email, import.meta.env.ADMIN_EMAILS);

const allDates = isAdmin ? SEASONS.flatMap((s) => daysInSeason(s.id)) : [];
const minDate = allDates[0] ?? "";
const maxDate = allDates[allDates.length - 1] ?? "";
const today = new Date().toISOString().slice(0, 10);
const initialDate = allDates.includes(today) ? today : maxDate;

const logins = isAdmin ? await listLogins(40).catch(() => []) : [];
const visits = isAdmin ? await listVisits(60).catch(() => []) : [];
const uniqueEmails = new Set([...logins.map((l) => l.email), ...visits.map((v) => v.email)]);

// Aggregate reactions + comments across all episodes for the activity feed.
type Activity =
  | { kind: "reaction"; date: string; emoji: string; email: string }
  | { kind: "comment"; date: string; id: string; author: string; text: string; at: string };
const activity: Activity[] = [];
if (isAdmin) {
  try {
    const eps = await listEpisodes();
    const dates = eps.map((e) => e.date);
    for (const ep of eps) {
      const [reacts, comms] = await Promise.all([
        getReactions(ep.date).catch(() => ({})),
        listComments(ep.date).catch(() => []),
      ]);
      for (const [emoji, emails] of Object.entries(reacts)) {
        for (const email of emails) {
          activity.push({ kind: "reaction", date: ep.date, emoji, email });
        }
      }
      for (const c of comms) {
        activity.push({ kind: "comment", date: ep.date, id: c.id, author: c.author, text: c.text, at: c.createdAt });
      }
    }
  } catch (err) {
    console.error("activity feed failed:", err);
  }
}

const fmtWhen = new Intl.DateTimeFormat("es-ES", {
  day: "2-digit", month: "short", hour: "2-digit", minute: "2-digit", timeZone: "Europe/Madrid",
});
function nameOnly(email: string): string {
  const at = email.indexOf("@");
  return at >= 0 ? email.slice(0, at) : email;
}
function episodeLabelFor(date: string): string {
  return episodeLabel(date, [date]) ?? date;
}
---

{!isAdmin ? (
  <Layout title="Admin · El OOO de Andrés" variant="hero">
    <div class="c--login-a">
      <ShowTitle size="medium" accent="acceso restringido" />
      <p class="c--login-a__subtitle">
        Esta zona es sólo para admins. Si crees que deberías tener acceso, dile a Eli que te añada.
      </p>
      <a class="c--login-a__btn" href="/">← Volver</a>
    </div>
  </Layout>
) : (
  <Layout title="Admin · El OOO de Andrés">
    <div class="c--admin-a">
      <div class="c--admin-a__top">
        <h1 class="c--page-a__title">Admin</h1>
        <a class="c--admin-a__btn is-ghost" href="/">← Volver</a>
      </div>

      <div class="c--admin-a__grid">
        <div class="c--admin-a__col">
          <h2 class="c--admin-a__h2">Editar capítulo</h2>
          <form id="episode-form" class="c--admin-a__form">
        <label class="c--admin-a__field">
          <span>Fecha</span>
          <input
            class="c--admin-a__input"
            type="date"
            name="date"
            required
            min={minDate}
            max={maxDate}
            value={initialDate}
          />
        </label>
        <label class="c--admin-a__field">
          <span>Título</span>
          <input class="c--admin-a__input" type="text" name="title" required maxlength="200" placeholder="🏖️ El que..." />
        </label>
        <div class="c--admin-a__actions">
          <button class="c--admin-a__btn" type="submit">Guardar</button>
          <button class="c--admin-a__btn is-ghost" type="button" id="logout-btn">Cerrar sesión</button>
          <p id="episode-status" class="c--admin-a__status" role="status"></p>
        </div>
      </form>

      <script>
        const form = document.getElementById("episode-form") as HTMLFormElement;
        const status = document.getElementById("episode-status")!;
        const dateSel = form.querySelector('input[name="date"]') as HTMLInputElement;
        const titleInput = form.querySelector('input[name="title"]') as HTMLInputElement;

        async function loadExisting() {
          try {
            const r = await fetch(`/api/episode?date=${encodeURIComponent(dateSel.value)}`);
            if (!r.ok) throw new Error("fetch failed");
            const data = await r.json();
            titleInput.value = data.episode?.title ?? "";
          } catch {
            titleInput.value = "";
          }
        }
        dateSel.addEventListener("change", loadExisting);
        loadExisting();

        form.addEventListener("submit", async (e) => {
          e.preventDefault();
          status.className = "c--admin-a__status";
          status.textContent = "Guardando...";
          const r = await fetch("/api/episode", {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              date: dateSel.value,
              title: titleInput.value,
              summary: "",
            }),
          });
          const data = await r.json();
          if (r.ok) {
            status.className = "c--admin-a__status is-ok";
            status.textContent = "Guardado ✓";
          } else {
            status.className = "c--admin-a__status is-error";
            status.textContent = data.error ?? "Error";
          }
        });

        document.getElementById("logout-btn")!.addEventListener("click", async () => {
          await fetch("/api/logout", { method: "POST" });
          location.reload();
        });
      </script>
        </div>

        <aside class="c--admin-a__col">
          <h2 class="c--admin-a__h2">Logins</h2>
          <p class="c--admin-a__hint">
            {uniqueEmails.size === 0
              ? "Aún nadie ha entrado."
              : `${uniqueEmails.size} ${uniqueEmails.size === 1 ? "persona" : "personas"} distintas · últimos ${logins.length} logins:`}
          </p>
          {logins.length > 0 && (
            <ul class="c--admin-a__logins">
              {logins.map((ev) => (
                <li>
                  <strong>{nameOnly(ev.email)}</strong>
                  <span class="c--admin-a__email">{ev.email}</span>
                  <span class="c--admin-a__when">{fmtWhen.format(new Date(ev.at))}</span>
                </li>
              ))}
            </ul>
          )}

          <h2 class="c--admin-a__h2">Visitas</h2>
          <p class="c--admin-a__hint">
            {visits.length === 0 ? "Sin visitas registradas todavía." : `Últimas ${visits.length} visitas (debounce 5 min):`}
          </p>
          {visits.length > 0 && (
            <ul class="c--admin-a__logins">
              {visits.map((v) => (
                <li>
                  <strong>{nameOnly(v.email)}</strong>
                  <span class="c--admin-a__email">{v.path ?? ""}</span>
                  <span class="c--admin-a__when">{fmtWhen.format(new Date(v.at))}</span>
                </li>
              ))}
            </ul>
          )}

          <h2 class="c--admin-a__h2">Actividad</h2>
          <p class="c--admin-a__hint">
            {activity.length === 0 ? "Sin reacciones ni comentarios." : `${activity.length} eventos:`}
          </p>
          {activity.length > 0 && (
            <ul class="c--admin-a__logins">
              {activity.map((a) => (
                <li>
                  {a.kind === "reaction" ? (
                    <>
                      <strong>{a.emoji}</strong>
                      <span class="c--admin-a__email">{nameOnly(a.email)} en {a.date}</span>
                      <span class="c--admin-a__when">reacción</span>
                    </>
                  ) : (
                    <>
                      <strong>{nameOnly(a.author)}</strong>
                      <span class="c--admin-a__email">"{a.text}" — {a.date}</span>
                      <span class="c--admin-a__when">{fmtWhen.format(new Date(a.at))}</span>
                    </>
                  )}
                </li>
              ))}
            </ul>
          )}
        </aside>
      </div>
    </div>
  </Layout>
)}
