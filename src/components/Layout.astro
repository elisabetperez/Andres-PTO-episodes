---
import "@/assets/sass/style.scss";

type Props = {
  title?: string;
  description?: string;
  variant?: "default" | "hero";
  showFooter?: boolean;
};

const {
  title = "El OOO de Andrés",
  description = "El OOO de Andrés como capítulos de Friends.",
  variant = "default",
  showFooter = true,
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <main class:list={["c--page-a", variant === "hero" && "is-hero"]}>
      <div class="c--page-a__inner">
        <slot />
        {showFooter && (
          <a class="c--tab-a" href="/admin">
            <span class="c--tab-a__label">Admin</span>
          </a>
        )}
      </div>
    </main>
  </body>
</html>
