---
import "@/assets/sass/style.scss";
import AuthGate from "@/components/AuthGate.astro";
import { verifySession, isAdminEmail } from "@/lib/auth";

type Props = {
  title?: string;
  description?: string;
  variant?: "default" | "hero";
  showFooter?: boolean;
  initialTheme?: string;
};

const {
  title = "Dev like an episode from Friends",
  description = "El OOO de Andrés contado día a día como una sitcom: capítulos, reacciones y cero reuniones.",
  variant = "default",
  showFooter = true,
  initialTheme = "cream",
} = Astro.props;

const token = Astro.cookies.get("pto_session")?.value;
const secret = import.meta.env.SESSION_SECRET;
const session = token && secret ? verifySession(token, secret) : null;
const isAuthed = !!session;
const isAdmin = isAdminEmail(session?.email, import.meta.env.ADMIN_EMAILS);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class:list={[!isAuthed && "is-gated"]} data-theme={initialTheme}>
    <main class:list={["c--page-a", variant === "hero" && "is-hero"]}>
      <div class="c--page-a__inner">
        <slot />
        {showFooter && isAdmin && (
          <a class="c--tab-a" href="/admin">
            <span class="c--tab-a__label">Admin</span>
          </a>
        )}
      </div>
    </main>
    {!isAuthed && <AuthGate />}
  </body>
</html>
