---
// Pop-up de login: mosaico de smileys arriba y abajo + pill kurobeni
// central con kicker, título y botón de Google dentro.
const FACE_COLORS = [
  "var(--pto-blush)",
  "var(--pto-peach)",
  "var(--pto-lilac)",
  "var(--pto-accent)",
  "var(--pto-coral)",
  "var(--pto-cream)",
  "var(--pto-peach)",
  "var(--pto-lilac)",
  "var(--pto-blush)",
  "var(--pto-accent)",
  "var(--pto-cream)",
  "var(--pto-coral)",
];
const BOTTOM_COLORS = [...FACE_COLORS].reverse();
---

<div class="c--auth-gate-a" aria-modal="true" role="dialog">
  <div class="c--auth-gate-a__row c--auth-gate-a__row--top">
    {FACE_COLORS.map((c) => (
      <span class="c--auth-gate-a__face" style={`background:${c}`}>
        <span class="c--auth-gate-a__mouth"></span>
      </span>
    ))}
  </div>

  <div class="c--auth-gate-a__pill">
    <p class="c--auth-gate-a__kicker">El OOO de Andrés</p>
    <h2 class="c--auth-gate-a__title">The One Where<br/>Andrés No Está.</h2>
    <p class="c--auth-gate-a__sub">Sólo cuentas <strong>@terrahq.com</strong> pueden ver el cotilleo 🫖</p>
    <a class="c--auth-gate-a__btn" href="/api/auth/google/start">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
        <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
        <path fill="#FBBC05" d="M5.84 14.1c-.22-.66-.35-1.36-.35-2.1s.13-1.44.35-2.1V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.83z"/>
        <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.83c.87-2.6 3.3-4.52 6.16-4.52z"/>
      </svg>
      Iniciar sesión con Google
    </a>
  </div>

  <div class="c--auth-gate-a__row c--auth-gate-a__row--bottom">
    {BOTTOM_COLORS.map((c) => (
      <span class="c--auth-gate-a__face" style={`background:${c}`}>
        <span class="c--auth-gate-a__mouth"></span>
      </span>
    ))}
  </div>
</div>
