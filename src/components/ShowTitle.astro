---
// Editorial-style title: roman uppercase line + italic accent line overlapping.
// Inspired by display posters with mixed weight + color.

type Props = {
  size?: "hero" | "medium";
  /** Italic accent text drawn over the title in the accent color. */
  accent?: string;
};
const { size = "hero", accent } = Astro.props;
---

<div class={`c--show-title-a c--show-title-a--${size}`}>
  <h1 class="c--show-title-a__main">
    <span class="c--show-title-a__line">El OOO</span>
    <span class="c--show-title-a__line">de Andrés</span>
  </h1>
  {accent && <span class="c--show-title-a__accent">{accent}</span>}
</div>
