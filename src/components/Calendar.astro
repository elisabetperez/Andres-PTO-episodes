---
import { SEASONS, isInAnySeason } from "@/config/seasons";
import { episodeNumber } from "@/lib/numbering";

type EpisodeInfo = { title: string; label: string };

type Props = {
  episodes: ReadonlyMap<string, EpisodeInfo>;
  today: string;            // YYYY-MM-DD
  initialSelected?: string; // YYYY-MM-DD — date to highlight on load
};

const { episodes, today, initialSelected } = Astro.props;
const allEntryDates = [...episodes.keys()];

const THEMES = ["cream", "peach", "lilac", "blush", "coral", "red"] as const;
function themeFor(date: string): string {
  const n = episodeNumber(date, allEntryDates);
  if (n === null) return "cream";
  return THEMES[(n - 1) % THEMES.length];
}

const MONTHS_ES = [
  "Enero", "Febrero", "Marzo", "Abril", "Mayo", "Junio",
  "Julio", "Agosto", "Septiembre", "Octubre", "Noviembre", "Diciembre",
];
const DOW_ES = ["L", "M", "X", "J", "V", "S", "D"];

// All months covered by seasons.
const allMonthsSet = new Set<string>();
for (const s of SEASONS) {
  const start = new Date(s.start + "T00:00:00Z");
  const end = new Date(s.end + "T00:00:00Z");
  const cur = new Date(Date.UTC(start.getUTCFullYear(), start.getUTCMonth(), 1));
  while (cur <= end) {
    allMonthsSet.add(`${cur.getUTCFullYear()}-${String(cur.getUTCMonth() + 1).padStart(2, "0")}`);
    cur.setUTCMonth(cur.getUTCMonth() + 1);
  }
}

// Only include months whose first day has already arrived (≤ today).
const todayYm = today.slice(0, 7);
const months = [...allMonthsSet].sort().filter((ym) => ym <= todayYm);

function buildMonth(ym: string) {
  const [y, m] = ym.split("-").map(Number);
  const first = new Date(Date.UTC(y, m - 1, 1));
  const last = new Date(Date.UTC(y, m, 0));
  const startOffset = (first.getUTCDay() + 6) % 7;
  type Status = "outside-month" | "outside-season" | "future" | "empty" | "filled";
  const cells: Array<{ date: string | null; status: Status; isToday: boolean }> = [];
  for (let i = 0; i < startOffset; i++) cells.push({ date: null, status: "outside-month", isToday: false });
  for (let d = 1; d <= last.getUTCDate(); d++) {
    const iso = `${y}-${String(m).padStart(2, "0")}-${String(d).padStart(2, "0")}`;
    let status: Status;
    if (iso > today) status = "future";
    else if (!isInAnySeason(iso)) status = "outside-season";
    else if (episodes.has(iso)) status = "filled";
    else status = "empty";
    cells.push({ date: iso, status, isToday: iso === today });
  }
  return { ym, name: `${MONTHS_ES[m - 1]} ${y}`, cells };
}
const monthData = months.map(buildMonth);

// Navigable dates: every clickable cell (filled or empty), sorted ASC.
const navigable = monthData
  .flatMap((mo) => mo.cells)
  .filter((c): c is { date: string; status: "filled" | "empty"; isToday: boolean } =>
    !!c.date && (c.status === "filled" || c.status === "empty"))
  .map((c) => c.date);

// Initial selected: the prop if provided AND navigable, else the last navigable.
const initialSelectedSafe =
  (initialSelected && navigable.includes(initialSelected) ? initialSelected : navigable[navigable.length - 1]) ?? "";

const initialYm = initialSelectedSafe.slice(0, 7) || months[months.length - 1] || todayYm;
---

<div
  class="c--calendar-a"
  data-initial-selected={initialSelectedSafe}
  data-navigable={JSON.stringify(navigable)}
  data-tooltip="The One Where Andrés No Está. Una sitcom diaria al estilo de Friends."
>
  <div class="c--calendar-a__nav">
    <button type="button" class="c--calendar-a__navbtn" data-dir="-1" aria-label="Día anterior">←</button>
    <button type="button" class="c--calendar-a__navbtn" data-dir="1" aria-label="Día siguiente">→</button>
  </div>

  {monthData.map((mo) => (
    <div class="c--calendar-a__month" data-month={mo.ym} hidden={mo.ym !== initialYm}>
      <div class="c--calendar-a__dow">
        {DOW_ES.map((d) => <span>{d}</span>)}
      </div>
      <div class="c--calendar-a__grid">
        {mo.cells.map((cell) => {
          if (!cell.date) return <span class="c--calendar-a__cell is-blank" />;
          const cls = [
            "c--calendar-a__cell",
            `is-${cell.status}`,
            cell.isToday ? "is-today" : "",
            cell.date === initialSelectedSafe ? "is-selected" : "",
          ].filter(Boolean).join(" ");
          const day = Number(cell.date.slice(8));
          if (cell.status === "outside-season" || cell.status === "future") {
            return <span class={cls}>{day}</span>;
          }
          const info = cell.status === "filled" ? episodes.get(cell.date) : null;
          return (
            <button
              type="button"
              class={cls}
              data-date={cell.date}
              data-title={info?.title ?? "Sin episodio"}
              data-label={info?.label ?? ""}
              data-status={cell.status}
              data-theme={themeFor(cell.date)}
            >{day}</button>
          );
        })}
      </div>
    </div>
  ))}
  <div class="c--calendar-a__indicator" data-indicator aria-hidden="true"></div>
</div>

<script>
  const root = document.querySelector(".c--calendar-a") as HTMLElement;
  if (root) {
    const monthEls = Array.from(root.querySelectorAll<HTMLElement>("[data-month]"));
    const navigable: string[] = JSON.parse(root.dataset.navigable || "[]");
    const prevBtn = root.querySelector('[data-dir="-1"]') as HTMLButtonElement;
    const nextBtn = root.querySelector('[data-dir="1"]') as HTMLButtonElement;
    const indicator = root.querySelector<HTMLElement>("[data-indicator]")!;

    let selectedDate = root.dataset.initialSelected || navigable[navigable.length - 1] || "";

    function findDayBtn(date: string): HTMLButtonElement | null {
      return root.querySelector<HTMLButtonElement>(`[data-date="${date}"]`);
    }

    function showMonthOf(date: string) {
      const ym = date.slice(0, 7);
      monthEls.forEach((el) => { el.hidden = el.dataset.month !== ym; });
    }

    function updateNavVisibility() {
      const idx = navigable.indexOf(selectedDate);
      prevBtn.hidden = idx <= 0;
      nextBtn.hidden = idx < 0 || idx >= navigable.length - 1;
    }

    function positionIndicator(animate: boolean) {
      const btn = findDayBtn(selectedDate);
      if (!btn || btn.offsetParent === null) {
        indicator.style.opacity = "0";
        return;
      }
      const rootRect = root.getBoundingClientRect();
      const cellRect = btn.getBoundingClientRect();
      if (!animate) indicator.style.transition = "none";
      indicator.style.top = `${cellRect.top - rootRect.top}px`;
      indicator.style.left = `${cellRect.left - rootRect.left}px`;
      indicator.style.width = `${cellRect.width}px`;
      indicator.style.height = `${cellRect.height}px`;
      indicator.style.opacity = "1";
      if (!animate) {
        // Force reflow then restore transition for future moves.
        void indicator.offsetWidth;
        indicator.style.transition = "";
      }
    }

    function selectDate(date: string, opts: { emit?: boolean; animate?: boolean } = {}) {
      const emit = opts.emit ?? true;
      const animate = opts.animate ?? true;
      selectedDate = date;
      showMonthOf(date);
      root.querySelectorAll(".is-selected").forEach((el) => el.classList.remove("is-selected"));
      const btn = findDayBtn(date);
      if (btn) {
        btn.classList.add("is-selected");
        positionIndicator(animate);
        if (emit) {
          root.dispatchEvent(new CustomEvent("calendar:select", {
            bubbles: true,
            detail: {
              date,
              status: btn.dataset.status!,
              title: btn.dataset.title ?? "",
              label: btn.dataset.label ?? "",
              theme: btn.dataset.theme ?? "cream",
            },
          }));
        }
      }
      updateNavVisibility();
    }

    // Initial paint — instant (no transition) so it lands directly on the day.
    if (selectedDate) selectDate(selectedDate, { emit: false, animate: false });

    // Keep the indicator aligned when the viewport resizes (cells reflow).
    let resizeTimer: number | undefined;
    window.addEventListener("resize", () => {
      window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(() => positionIndicator(false), 80);
    });

    root.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      const navBtn = target.closest<HTMLButtonElement>("[data-dir]");
      if (navBtn) {
        const dir = Number(navBtn.dataset.dir);
        const idx = navigable.indexOf(selectedDate);
        const nextIdx = idx + dir;
        if (nextIdx >= 0 && nextIdx < navigable.length) {
          selectDate(navigable[nextIdx]);
        }
        return;
      }
      const dayBtn = target.closest<HTMLButtonElement>("[data-date]");
      if (dayBtn) selectDate(dayBtn.dataset.date!);
    });
  }
</script>
